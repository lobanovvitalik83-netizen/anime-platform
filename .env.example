APP_NAME=Media Bridge
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_SECRET_KEY=change-me
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/media_bridge

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MEDIA_UPLOAD_CHAT_ID=
TELEGRAM_HELP_CONTACT=

MEDIA_STORAGE_BACKEND=auto
PUBLIC_BASE_URL=

S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=media-bridge

YANDEX_DISK_OAUTH_TOKEN=
YANDEX_DISK_BASE_PATH=app:/media-bridge

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=

SESSION_COOKIE_NAME=media_bridge_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

CODE_LENGTH=8

ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_MIME=video/mp4
MAX_IMAGE_SIZE_BYTES=5242880
MAX_VIDEO_SIZE_BYTES=52428800

DATA_DIR=/app/data
MAX_AVATAR_SIZE_BYTES=2097152

LOGIN_RATE_LIMIT_ATTEMPTS=7
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
REPORT_RATE_LIMIT_ATTEMPTS=6
REPORT_RATE_LIMIT_WINDOW_SECONDS=120
AUDIT_RETENTION_DAYS=120
NOTIFICATIONS_RETENTION_DAYS=45
IMPORT_JOBS_RETENTION_DAYS=30
MAX_BULK_DELETE_ITEMS=50
