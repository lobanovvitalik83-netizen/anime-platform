APP_NAME=Media Bridge
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=3000
APP_SECRET_KEY=change_me_to_a_long_random_secret
APP_LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_me

SESSION_COOKIE_NAME=media_bridge_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

CODE_LENGTH=8

TELEGRAM_MEDIA_UPLOAD_CHAT_ID=

ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_MIME=video/mp4
MAX_IMAGE_SIZE_BYTES=5242880
MAX_VIDEO_SIZE_BYTES=52428800

DATA_DIR=/app/data
MAX_AVATAR_SIZE_BYTES=2097152
